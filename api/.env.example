# Copy to api/.env and fill in. The DB_* / SUPABASE_* values are the same ones
# the Streamlit secrets file holds — the backend reads them from the environment.

# --- Database (shared with the Streamlit app & workers) ---
DB_PASSWORD=your-supabase-db-password
SUPABASE_HOST=aws-0-<region>.pooler.supabase.com
SUPABASE_PORT=5432
SUPABASE_USER=postgres.<project-ref>
SUPABASE_DBNAME=postgres

# --- Companies House (director enrichment on approve) ---
# Same key the Streamlit app / worker use. Without it, director enrichment
# returns "No directors found".
CH_API_KEY=your-companies-house-rest-key

# --- API auth ---
# Optional: defaults to DB_PASSWORD if unset. Set a dedicated value in production.
JWT_SECRET=
# Comma-separated allowed frontend origins.
CORS_ORIGINS=http://localhost:3000
