# Keep the API image small and secret-free. The frontend and the local venv are
# irrelevant to the API; secrets come from Railway env vars, never the image.
.venv-api/
venv/
.venv/
frontend/
node_modules/
**/__pycache__/
*.pyc
.git/
.github/
# Secrets come from Railway Variables, NEVER the image. `COPY . .` in
# Dockerfile.api would otherwise bake a local .env into the layers — harmless on
# Railway (it builds from git, where .env is ignored) but not on a local
# `docker build`. Keep both the file and any variants out.
.env
.env.*
!.env.example
*.zip
digests/
lead_score_distribution.png
# The API never runs the model (it only reads the stored model_score column), so
# keep the committed model out of its image. The worker gets it from git.
lead_model.pkl
.pytest_cache/
.ruff_cache/
