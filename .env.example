# Copy to `.env` at the project ROOT and fill in. This ONE file feeds everything
# that runs locally — the API, the worker, and the scripts (rerun_pipeline.py,
# enrich_local.py, sic_data.py, the ch_* tools) — via env_loader.py.
# On Railway there is no .env: set these as service Variables instead.
#
# `.env` is gitignored. NEVER commit real values.
# Quoting: this is NOT TOML. A value containing " or ) or ; needs no quotes and
# no escaping — paste it raw after the "=".

# --- Database (Supabase; use the SESSION POOLER values, not the direct connection) ---
# Supabase dashboard -> Connect -> Session pooler.
DB_PASSWORD=your-supabase-db-password
SUPABASE_HOST=aws-0-<region>.pooler.supabase.com
SUPABASE_PORT=5432
SUPABASE_USER=postgres.<project-ref>
SUPABASE_DBNAME=postgres

# --- Companies House ---
# REST key: lead sourcing + director enrichment. Without it, sourcing 401s and
# director enrichment returns "No directors found".
CH_API_KEY=your-companies-house-rest-key
# STREAMING key: a SEPARATE CH application from the REST key above, so one leak
# can't burn both. Only used by the ch_stream.py listener.
CH_STREAM_KEY=your-companies-house-streaming-key

# --- API auth ---
# Signs the login JWTs. Set a long random string:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# If blank or absent it falls back to DB_PASSWORD, which works but means one
# leaked value opens both the database and every user's session.
JWT_SECRET=
# Comma-separated allowed frontend origins (exact scheme+host, no trailing slash).
CORS_ORIGINS=http://localhost:3000
